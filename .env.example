# Copie para .env (ou .env.homolog) e preencha. NUNCA versionar o arquivo real.

# IA
GEMINI_API_KEY=

# URLs
FRONTEND_URL=http://localhost:8090
API_URL=http://localhost:8010

# Banco de dados (Postgres)
DB_HOST=
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_PORT=5432
DB_SCHEMA=portal_chamado_homolog

# Google Cloud — caminho do arquivo de service account (fora do versionamento)
GOOGLE_APPLICATION_CREDENTIALS=./credentials/google_credentials.json

# Chave de criptografia (equipamentos)
EQUIP_CRYPTO_KEY=
